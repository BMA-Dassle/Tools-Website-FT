# pnpm workspace settings.
# - node-linker=isolated keeps strict per-package node_modules (the main reason we picked pnpm).
# - strict-peer-dependencies=false because Next.js + React peer-dep mismatches are noisy
#   and we'll handle real conflicts case-by-case.
# - auto-install-peers=true is pnpm 8+ default; explicit for clarity.
node-linker=isolated
strict-peer-dependencies=false
auto-install-peers=true
