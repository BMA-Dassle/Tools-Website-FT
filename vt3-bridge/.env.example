# Copy to .env.local for local dev (do NOT commit the real .env.local).
# In production these are set via `fly secrets set` or Railway env panel.

# VT3 / Voxtelesys Viewpoint credentials. Same values as
# fasttrax-web's VT3_USERNAME / VT3_PASSWORD env vars.
VT3_USERNAME=
VT3_PASSWORD=

# Where this bridge POSTs each pushed event. Production points at
# https://fasttraxent.com/api/webhooks/vt3-video-event. For local dev
# you can point at https://your-tunnel.ngrok.io/... or skip this and
# use PROBE=1 instead.
WEBHOOK_URL=

# Shared secret. Mirror this exact value into the fasttrax-web Vercel
# project as VT3_BRIDGE_SECRET so the webhook can validate it.
# Generate one with: openssl rand -hex 32
WEBHOOK_SECRET=

# Optional. Set to "1" to log every pushed event payload to stdout
# WITHOUT forwarding to the webhook. Use this once during dev to
# discover the actual SSE event schemas (HAR can't capture SSE
# bodies). Leave unset / "0" in production.
# PROBE=1

# Optional. "debug" emits raw frames + parsed payloads. "info" (default)
# logs only event-level summaries.
# LOG_LEVEL=info
