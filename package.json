{
  "name": "tools-website-ft",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "fasttrax-web",
    "kart-timing-bridge",
    "vt3-bridge",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
