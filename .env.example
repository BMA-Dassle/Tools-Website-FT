# =============================================================================
# Tools-Website-FT — root .env.example
# =============================================================================
# Copy to .env.local for local development (.env.local is git-ignored).
# Production values live in Vercel project env. Bridges have their own
# .env.example files in their respective directories.
#
# LEGEND
#   [required]  app refuses to boot / a critical feature breaks without it
#   [optional]  app boots, feature degrades gracefully
#   [dev-only]  used only when NODE_ENV !== "production"
# =============================================================================


# -----------------------------------------------------------------------------
# Core / runtime
# -----------------------------------------------------------------------------

# [required] Public URL of the deployed site. Used for absolute links in
# emails, SMS, og:image, etc. Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set automatically by Vercel. Don't set manually in local dev.
# VERCEL_GIT_COMMIT_SHA=


# -----------------------------------------------------------------------------
# Database / cache
# -----------------------------------------------------------------------------

# [required] Neon (Postgres) connection string. Shared dev DB credentials live
# in 1Password vault "FastTrax Dev". Includes ?sslmode=require.
DATABASE_URL=

# [required] Upstash Redis. Either REDIS_URL (ioredis) OR KV_REST_API_TOKEN+KV_URL
# (Vercel KV REST). The codebase reads both styles depending on call site.
REDIS_URL=
KV_URL=
KV_REST_API_TOKEN=
REDIS_TOKEN=


# -----------------------------------------------------------------------------
# Square — payments, customers, gift cards, loyalty (PRIMARY BACKEND in v2)
# -----------------------------------------------------------------------------

# [required] Square access token. Use a SANDBOX token for local dev.
# Get one at https://developer.squareup.com → Applications → Sandbox.
SQUARE_ACCESS_TOKEN=

# [required, client-side] Square application ID (sandbox app ID locally).
# Loaded by the Web Payments SDK in <PaymentForm /> + <BowlingPaymentStep />.
NEXT_PUBLIC_SQUARE_APP_ID=

# [optional] Location ID overrides. Most routes have hardcoded location maps;
# these are fallbacks for ad-hoc scripts.
SQUARE_LOCATION_ID=
SQUARE_FT_LOCATION_ID=


# -----------------------------------------------------------------------------
# BMI — attractions + racing reservation backend
# -----------------------------------------------------------------------------

# [required] BMI Leisure API root. Default: https://api.bmileisure.com
BMI_API_URL=
BMI_USERNAME=
BMI_PASSWORD=
BMI_CLIENT_KEY=
BMI_SUBSCRIPTION_KEY=

# [optional] BMI Office API (admin-side ops: bill cancel, note write).
BMI_OFFICE_USERNAME=
BMI_OFFICE_PASSWORD_B64=


# -----------------------------------------------------------------------------
# Conq (Qubica AMF) — bowling reservation backend
# -----------------------------------------------------------------------------

# [required for bowling] OAuth2 client credentials for QAMF Bowling Reservations.
QAMF_BOWLING_CLIENT_ID=
QAMF_BOWLING_CLIENT_SECRET=
QAMF_BOWLING_SUBSCRIPTION_KEY=

# [optional] Webhook signature secret for QAMF push events.
QAMF_BOWLING_WEBHOOK_SECRET=

# [optional] Legacy QAMF subscription key (non-bowling endpoints).
QAMF_SUBSCRIPTION_KEY=


# -----------------------------------------------------------------------------
# Pandora — racer identity, credits, party leads
# -----------------------------------------------------------------------------

# [required] Pandora admin bearer (also called "swagger admin key" in code).
SWAGGER_ADMIN_KEY=

# [optional] Pandora deposit kind ID for POV/credit attribution.
VIEWPOINT_DEPOSIT_KIND_ID=


# -----------------------------------------------------------------------------
# KBF — Kids Bowl Free
# -----------------------------------------------------------------------------

# [required for KBF] Password for kidsbowlfree.com CSV ingest cron.
KBF_PASSWORD=


# -----------------------------------------------------------------------------
# VT3 — video event stream
# -----------------------------------------------------------------------------

# [required for video features] Voxtelesys Viewpoint credentials.
VT3_USERNAME=
VT3_PASSWORD=
VT3_SITE_ID=

# [required for video] Shared secret used by vt3-bridge to sign webhook payloads.
VT3_BRIDGE_SECRET=

# [optional] "1" enables Pandora session → VT3 customer link.
VT3_LINK_CUSTOMER_ENABLED=


# -----------------------------------------------------------------------------
# Kart timing bridge
# -----------------------------------------------------------------------------

# [required for race-day features] Shared secret signed by kart-timing-bridge.
KART_BRIDGE_SECRET=


# -----------------------------------------------------------------------------
# SMS — Twilio + Voxtelesys
# -----------------------------------------------------------------------------

# Twilio (primary) — outbound SMS confirmations + 2FA.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE_NUMBER=

# Voxtelesys (fallback SMS provider).
VOX_API_KEY=
VOX_FROM_NUMBER=

# [optional] Generic SMS access token (used by older send paths).
SMS_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# Email — SendGrid
# -----------------------------------------------------------------------------

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=


# -----------------------------------------------------------------------------
# Microsoft Teams bot + Graph
# -----------------------------------------------------------------------------

BOT_APP_ID=
BOT_APP_SECRET=
GRAPH_TENANT_ID=
PORTAL_FORWARD_SECRET=

# [optional] 3CX (legacy webhook auth).
THREECX_CLIENT_ID=
THREECX_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Admin auth — see middleware.ts
# -----------------------------------------------------------------------------

ADMIN_SECRET_TOKEN=
ADMIN_CAMERA_TOKEN=
ADMIN_ETICKETS_TOKEN=
ADMIN_EMBED_SECRET=

# [optional] Comma-separated allow-list of admin IPs.
# ADMIN_ALLOWED_IPS=

# Comma-separated allow-list of API keys for /api/sales/*.
SALES_API_KEYS=


# -----------------------------------------------------------------------------
# Booking API (legacy webhook auth)
# -----------------------------------------------------------------------------

BOOKING_API_KEY=
BOOKING_HMAC_SECRET=


# -----------------------------------------------------------------------------
# Vercel Blob (file uploads)
# -----------------------------------------------------------------------------

BLOB_READ_WRITE_TOKEN=


# -----------------------------------------------------------------------------
# SEO verification
# -----------------------------------------------------------------------------

GOOGLE_SITE_VERIFICATION_FT=
GOOGLE_SITE_VERIFICATION_HP=
BING_SITE_VERIFICATION_FT=
BING_SITE_VERIFICATION_HP=

# [optional] IndexNow API key (search-engine ping on new content).
INDEXNOW_KEY=

# [optional] Bing Webmaster API (programmatic submissions).
BING_WEBMASTER_TOKEN=
BING_WEBMASTER_API_KEY=

# [optional] Google service-account JSON for indexing API. Either inline JSON
# or a file path depending on the call site.
GOOGLE_SERVICE_ACCOUNT_KEY=


# -----------------------------------------------------------------------------
# Feature flags — migrating to Statsig in PR8 (do not add new flags here)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_ROOKIE_PACK_ENABLED=
NEXT_PUBLIC_ULTIMATE_QUALIFIER_ENABLED=
NEXT_PUBLIC_RACE_PACK_VIA_DEPOSIT=


# -----------------------------------------------------------------------------
# Local dev only
# -----------------------------------------------------------------------------

# [dev-only] Used by lib/api.ts in some scripts. Default: http://localhost:3000.
# API_URL=
