# Copy to .env.local for local dev. Production values live in
# Railway env (railway variables set ...).

# WebSocket URL of the kart timing broadcast endpoint.
# Default: ws://68.171.192.138:1001
WS_URL=ws://68.171.192.138:1001

# Where this bridge POSTs each inbound message.
WEBHOOK_URL=https://fasttraxent.com/api/webhooks/kart-timing-event

# Shared secret. USE THE SAME VALUE the vt3-bridge service is using —
# the Vercel-side webhook validates against VT3_BRIDGE_SECRET (already
# set on Vercel). One secret, both bridges.
WEBHOOK_SECRET=

# Optional. "1" → log every parsed message to stdout. Forwards either way.
# PROBE=1

# Optional. "debug" → raw frames + reconnect timing.
# LOG_LEVEL=info
